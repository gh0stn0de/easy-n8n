# PostgreSQL
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me_strong_password

# n8n
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace_with_a_random_32_char_hex_string

# Update these for production (domain/reverse proxy)
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678

# Timezone
GENERIC_TIMEZONE=Europe/London
TZ=Europe/London
