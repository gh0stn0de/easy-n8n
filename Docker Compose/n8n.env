```
# n8n environment variables for Docker Compose
# Replace placeholder values as appropriate before deploying

# Server
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
GENERIC_TIMEZONE=UTC

# Basic auth (enable in compose with N8N_BASIC_AUTH_ACTIVE=true)
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=n8n_user
N8N_BASIC_AUTH_PASSWORD=n8n_password

# Database (Postgres example)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=change_me

# If you prefer SQLite use:
# DB_TYPE=sqlite
# DB_SQLITE_VACUUM_ON_STARTUP=true
# DB_SQLITE_DATABASE=/data/database.sqlite

# Redis (for queue or advanced setups) - optional
REDIS_HOST=redis
REDIS_PORT=6379

# Execution mode
EXECUTIONS_PROCESS=main
EXECUTIONS_PROCESS_ON_WORKER=false

# Allow external modules in function nodes (comma separated)
NODE_FUNCTION_ALLOW_EXTERNAL=* 

# Webhook
WEBHOOK_URL=
# If behind a proxy / tunnel, set WEBHOOK_TUNNEL_URL=https://your-public-url
WEBHOOK_TUNNEL_URL=

# Additional settings
N8N_BASIC_AUTH_HASH=false
N8N_LOG_LEVEL=info
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

```
